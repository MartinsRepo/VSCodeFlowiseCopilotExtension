{
  "name": "flowise-copilot",
  "displayName": "Flowise-CoPilot",
  "description": "Run Flowise chatflows directly from VS Code chat.",
  "version": "0.0.1",
  "publisher": "MartinHummel",
  "icon": "images/flowise.png",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/MartinsRepo/VSCodeFlowiseCopilotExtension.git"
  },
  "homepage": "https://github.com/MartinsRepo/VSCodeFlowiseCopilotExtension#readme",
  "bugs": {
    "url": "https://github.com/MartinsRepo/VSCodeFlowiseCopilotExtension/issues"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "keywords": [
    "flowise",
    "chat",
    "copilot",
    "ai",
    "chatflow",
    "llm"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flowise.insertProjectId",
        "title": "Insert Flowise Project ID"
      },
      {
        "command": "flowise.clearProjectId",
        "title": "Clear Flowise Project ID"
      }
    ],
    "chatParticipants": [
      {
        "id": "flowise.chat",
        "name": "flowise",
        "description": "Führt Flows in Flowise aus.",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
